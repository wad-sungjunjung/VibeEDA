# ── Vibe EDA 환경변수 ─────────────────────────────────────────────────────────
# 실제 값은 .env에 저장 (gitignored)

# Gemini API (Vibe Chat)
GEMINI_API_KEY=your-gemini-api-key

# Claude API (Agent Mode)
ANTHROPIC_API_KEY=your-anthropic-api-key

# 모델 설정 (기본값 사용 권장)
DEFAULT_VIBE_MODEL=gemini-2.5-flash
DEFAULT_AGENT_MODEL=claude-opus-4-7

# CORS (로컬 개발) — 프론트 포트가 9700
ALLOWED_ORIGINS=["http://localhost:9700","http://localhost:4173"]

# Snowflake (SQL 셀 실행 시 필요)
# SNOWFLAKE_ACCOUNT=your-account.region
# SNOWFLAKE_USER=your-username
# SNOWFLAKE_PASSWORD=your-password
# SNOWFLAKE_DATABASE=your-database
# SNOWFLAKE_WAREHOUSE=your-warehouse
# SNOWFLAKE_SCHEMA=PUBLIC
