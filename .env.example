# ── Frontend 환경변수 (Vite 빌드 시 포함) ─────────────────────────────
# 실제 값은 .env.local에 저장 (gitignore됨)

# 백엔드 API Base URL (기본 포트 4750)
VITE_API_BASE_URL=http://localhost:4750/v1

# Google OAuth Client ID (프론트엔드 노출 가능)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# 앱 환경
VITE_APP_ENV=development
